{
  "name": "appium-mobile-framework",
  "version": "1.0.0",
  "description": "Production-ready Appium v2 + WebdriverIO mobile automation framework with TypeScript, POM, Allure reporting, and CI/CD integration",
  "main": "index.js",
  "scripts": {
    "test:android": "wdio run config/wdio.android.conf.ts",
    "test:ios": "wdio run config/wdio.ios.conf.ts",
    "test:parallel": "wdio run config/wdio.parallel.conf.ts",
    "test:android:login": "wdio run config/wdio.android.conf.ts --spec tests/login.spec.ts",
    "test:android:crud": "wdio run config/wdio.android.conf.ts --spec tests/crud.spec.ts",
    "test:android:navigation": "wdio run config/wdio.android.conf.ts --spec tests/navigation.spec.ts",
    "test:ios:login": "wdio run config/wdio.ios.conf.ts --spec tests/login.spec.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "install:apk": "ts-node scripts/install-apk.ts",
    "install:ipa": "ts-node scripts/install-ipa.ts",
    "clean": "rimraf allure-results allure-report .tmp",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.0",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@wdio/allure-reporter": "^8.28.6",
    "@wdio/appium-service": "^8.28.6",
    "@wdio/cli": "^8.28.6",
    "@wdio/local-runner": "^8.28.6",
    "@wdio/mocha-framework": "^8.28.6",
    "@wdio/spec-reporter": "^8.28.6",
    "wdio-video-reporter": "^5.1.2",
    "allure-commandline": "^2.27.0",
    "appium": "^2.4.1",
    "appium-uiautomator2-driver": "^2.36.1",
    "appium-xcuitest-driver": "^5.12.1",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webdriverio": "^8.28.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "mobile",
    "automation",
    "typescript",
    "pom",
    "android",
    "ios"
  ],
  "author": "",
  "license": "MIT"
}
# ─────────────────────────────────────────────
# Appium Mobile Framework - Environment Config
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Android ──────────────────────────────────
ANDROID_DEVICE_NAME=Pixel_7_API_34
ANDROID_PLATFORM_VERSION=14.0
APP_PACKAGE=com.favorappllc.mobile
APP_ACTIVITY=com.favorappllc.mobile.MainActivity
APK_PATH=./apps/FavorApp.apk

# ── iOS ───────────────────────────────────────
IOS_DEVICE_NAME=iPhone 15
IOS_PLATFORM_VERSION=17.2
IOS_BUNDLE_ID=net.favortech.favorapp
IPA_PATH=./apps/FavorApp.ipa
IOS_UDID=auto

# ── Appium Server ─────────────────────────────
APPIUM_HOST=localhost
APPIUM_PORT=4723

# ── App Credentials ───────────────────────────
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=Test@1234
INVALID_EMAIL=invalid@test.com
INVALID_PASSWORD=WrongPass123

# ── Test Config ───────────────────────────────
DEFAULT_TIMEOUT=30000
IMPLICIT_WAIT=5000
MAX_RETRIES=2
